#!/usr/bin/env bash
# ============================================================================
# dee — Devlmer Ecosystem Engine CLI v3.0
#
# Global command for managing DEE installations.
# Installed to ~/.local/bin/dee by the installer.
#
# Usage:
#   dee update [path]        Update an existing installation
#   dee install [path]       Install ecosystem on a project
#   dee status [path]        Show installation status
#   dee doctor [path]        Run health check
#   dee version              Show version info
#   dee help                 Show this help
#   dee uninstall [path]     Remove ecosystem from a project
# ============================================================================

set -euo pipefail

VERSION="3.1.1"
REPO_URL="https://github.com/Soyelijah/devlmer-ecosystem-engine.git"
TMP_DIR="/tmp/dee-$$"

# ── Colors (use $'...' so escape bytes are real, not literal) ──
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'
MAGENTA=$'\033[0;35m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'

# ── Helpers ──
log_info()    { echo -e "  ${CYAN}ℹ${RESET} $1"; }
log_success() { echo -e "  ${GREEN}✓${RESET} $1"; }
log_warning() { echo -e "  ${YELLOW}⚠${RESET} $1"; }
log_error()   { echo -e "  ${RED}✗${RESET} $1"; }

cleanup() { rm -rf "${TMP_DIR}" 2>/dev/null || true; }
trap cleanup EXIT

# Resolve project path — if not given, try current directory
resolve_path() {
    local path="${1:-$(pwd)}"
    path="${path/#\~/$HOME}"
    if [[ -d "${path}" ]]; then
        path="$(cd "${path}" && pwd)"
    fi
    echo "${path%/}"
}

# Clone latest repo to tmp
fetch_latest() {
    log_info "Downloading latest version..."
    rm -rf "${TMP_DIR}"
    if git clone --depth 1 --quiet "${REPO_URL}" "${TMP_DIR}" 2>/dev/null; then
        log_success "Latest version ready"
    else
        log_error "Failed to download. Check your internet connection."
        exit 1
    fi
}

# Check if a project has DEE installed
has_dee() {
    local path="$1"
    [[ -d "${path}/.claude" ]] && [[ -d "${path}/.claude/skills" ]]
}

show_header() {
    echo ""
    echo -e "${BOLD}${CYAN}  dee${RESET} ${DIM}— Devlmer Ecosystem Engine v${VERSION}${RESET}"
    echo ""
}

# ============================================================================
# COMMANDS
# ============================================================================

cmd_help() {
    show_header
    cat << EOF
${BOLD}USO${RESET}
    dee <comando> [ruta]

    Si no pones una ruta, se usa la carpeta donde estés parado.

${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}

${BOLD}📦 INSTALACIÓN Y DESINSTALACIÓN${RESET}

    ${GREEN}dee install${RESET} [ruta]
        Instala el ecosistema completo en un proyecto.
        Detecta tu stack, instala skills, MCPs, agents, hooks
        y slash commands. Solo necesitas hacerlo una vez por proyecto.

        Ejemplos:
          dee install                     Instalar en la carpeta actual
          dee install ~/Projects/mi-app   Instalar en un proyecto específico

    ${GREEN}dee uninstall${RESET} [ruta]
        Elimina el ecosistema de un proyecto. Tus API keys se
        conservan por seguridad. Pide confirmación antes de borrar.

        Ejemplo:
          dee uninstall                   Desinstalar de la carpeta actual

${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}

${BOLD}🔄 ACTUALIZACIÓN${RESET}

    ${GREEN}dee update${RESET} [ruta]
        Actualiza un proyecto a la última versión: skills nuevos,
        hooks mejorados y slash commands. Tu configuración personal
        (API keys, MCPs, CLAUDE.md) NO se toca.
        También actualiza el propio CLI si hay versión nueva.

        Ejemplos:
          dee update                      Actualizar proyecto actual
          dee update ~/Projects/mi-app    Actualizar otro proyecto

    ${GREEN}dee self-update${RESET}
        Actualiza SOLO el programa dee (este CLI) a la última versión.
        No necesitas estar dentro de un proyecto. Útil cuando
        quieres los últimos comandos sin tocar ningún proyecto.

        Alias: ${DIM}dee upgrade${RESET}, ${DIM}dee selfupdate${RESET}

        Ejemplo:
          dee self-update                 Actualizar dee desde cualquier lugar

${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}

${BOLD}🔍 DIAGNÓSTICO${RESET}

    ${GREEN}dee status${RESET} [ruta]
        Muestra qué hay instalado en un proyecto: cuántos skills,
        commands, agents y MCPs tienes, qué dominio se detectó,
        y el tamaño de los archivos de configuración.

        Ejemplo:
          dee status                      Ver estado del proyecto actual

    ${GREEN}dee doctor${RESET} [ruta]
        Revisa la salud de tu instalación con un score de 0 a 100.
        Verifica que los archivos existan, que los skills tengan
        contenido real, que los hooks funcionen y que los MCPs
        estén configurados. Te dice exactamente qué arreglar.

        Ejemplo:
          dee doctor                      Diagnóstico del proyecto actual

${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}

${BOLD}ℹ️  INFORMACIÓN${RESET}

    ${GREEN}dee version${RESET}
        Muestra la versión instalada de dee.

        Alias: ${DIM}dee -v${RESET}, ${DIM}dee --version${RESET}

    ${GREEN}dee help${RESET}
        Muestra esta ayuda.

        Alias: ${DIM}dee -h${RESET}, ${DIM}dee --help${RESET}

${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}

${BOLD}🎯 ¿POR DÓNDE EMPIEZO?${RESET}

    ${CYAN}Primera vez:${RESET}
      cd ~/tu-proyecto && dee install

    ${CYAN}Ya lo tienes instalado:${RESET}
      dee update

    ${CYAN}Quieres ver cómo está todo:${RESET}
      dee doctor

    ${CYAN}Quieres la última versión del CLI:${RESET}
      dee self-update

EOF
}

cmd_version() {
    echo -e "${BOLD}dee${RESET} v${VERSION} — Devlmer Ecosystem Engine"
    echo -e "${DIM}https://github.com/Soyelijah/devlmer-ecosystem-engine${RESET}"
}

cmd_self_update() {
    show_header
    log_info "Buscando última versión del CLI..."

    local tmp="/tmp/dee-self-$$"
    rm -rf "${tmp}"
    if ! git clone --depth 1 --quiet "${REPO_URL}" "${tmp}" 2>/dev/null; then
        log_error "No se pudo descargar. Revisa tu conexión a internet."
        rm -rf "${tmp}"
        exit 1
    fi

    local new_dee="${tmp}/bin/dee"
    if [[ ! -f "${new_dee}" ]]; then
        log_error "No se encontró bin/dee en el repositorio."
        rm -rf "${tmp}"
        exit 1
    fi

    # Find where dee is installed
    local installed_dee
    installed_dee=$(command -v dee 2>/dev/null || echo "${HOME}/.local/bin/dee")

    # Compare by file content (checksum), not just version number
    # This catches fixes where version didn't change but code did
    local new_checksum old_checksum
    if command -v md5sum &>/dev/null; then
        new_checksum=$(md5sum "${new_dee}" 2>/dev/null | cut -d' ' -f1)
        old_checksum=$(md5sum "${installed_dee}" 2>/dev/null | cut -d' ' -f1)
    elif command -v md5 &>/dev/null; then
        # macOS uses md5 instead of md5sum
        new_checksum=$(md5 -q "${new_dee}" 2>/dev/null)
        old_checksum=$(md5 -q "${installed_dee}" 2>/dev/null)
    else
        # Fallback: compare file sizes
        new_checksum=$(wc -c < "${new_dee}" 2>/dev/null | tr -d ' ')
        old_checksum=$(wc -c < "${installed_dee}" 2>/dev/null | tr -d ' ')
    fi

    if [[ "${new_checksum}" == "${old_checksum}" ]]; then
        log_success "Ya tienes la última versión: v${VERSION}"
        rm -rf "${tmp}"
        echo ""
        return 0
    fi

    local new_ver
    new_ver=$(grep '^VERSION=' "${new_dee}" 2>/dev/null | head -1 | cut -d'"' -f2)

    cp "${new_dee}" "${installed_dee}"
    chmod +x "${installed_dee}"
    rm -rf "${tmp}"

    echo ""
    if [[ "${new_ver}" != "${VERSION}" ]]; then
        log_success "CLI actualizado: v${VERSION} → v${new_ver}"
    else
        log_success "CLI actualizado a la última versión (v${new_ver})"
    fi
    echo ""
    echo -e "  ${DIM}Ubicación: ${installed_dee}${RESET}"
    echo ""
}

cmd_install() {
    local target
    target=$(resolve_path "${1:-}")
    show_header

    if has_dee "${target}"; then
        log_warning "DEE already installed at: ${target}"
        echo ""
        echo -e "  Use ${BOLD}dee update${RESET} to update, or ${BOLD}dee install --force${RESET} to reinstall."
        echo ""

        if [[ "${2:-}" == "--force" ]] || [[ "${1:-}" == "--force" ]]; then
            log_info "Force reinstall requested..."
        else
            return 0
        fi
    fi

    fetch_latest
    echo ""
    log_info "Installing to: ${target}"
    echo ""
    bash "${TMP_DIR}/install.sh" "${target}"
}

cmd_update() {
    local target
    target=$(resolve_path "${1:-}")
    show_header

    if ! has_dee "${target}"; then
        log_error "No DEE installation found at: ${target}"
        echo ""
        echo -e "  Use ${BOLD}dee install${RESET} to install first."
        echo ""
        return 1
    fi

    fetch_latest

    # ── Self-update: update the dee CLI binary itself ──
    local new_dee="${TMP_DIR}/bin/dee"
    local installed_dee
    installed_dee=$(command -v dee 2>/dev/null || echo "${HOME}/.local/bin/dee")
    if [[ -f "${new_dee}" && -f "${installed_dee}" ]]; then
        # Compare by checksum, not just version (catches code fixes within same version)
        local new_ck old_ck
        if command -v md5 &>/dev/null; then
            new_ck=$(md5 -q "${new_dee}" 2>/dev/null)
            old_ck=$(md5 -q "${installed_dee}" 2>/dev/null)
        elif command -v md5sum &>/dev/null; then
            new_ck=$(md5sum "${new_dee}" 2>/dev/null | cut -d' ' -f1)
            old_ck=$(md5sum "${installed_dee}" 2>/dev/null | cut -d' ' -f1)
        else
            new_ck=$(wc -c < "${new_dee}" 2>/dev/null | tr -d ' ')
            old_ck=$(wc -c < "${installed_dee}" 2>/dev/null | tr -d ' ')
        fi
        if [[ "${new_ck}" != "${old_ck}" ]]; then
            local new_ver
            new_ver=$(grep '^VERSION=' "${new_dee}" 2>/dev/null | head -1 | cut -d'"' -f2)
            cp "${new_dee}" "${installed_dee}"
            chmod +x "${installed_dee}"
            log_success "CLI actualizado a v${new_ver:-${VERSION}}"
        fi
    fi

    bash "${TMP_DIR}/update.sh" "${target}"
}

cmd_status() {
    local target
    target=$(resolve_path "${1:-}")
    show_header

    if ! has_dee "${target}"; then
        log_error "No DEE installation found at: ${target}"
        echo ""
        echo -e "  Use ${BOLD}dee install${RESET} to install first."
        echo ""
        return 1
    fi

    # Count components
    local skills=0 commands=0 agents=0 mcps=0 hooks=0
    skills=$(find "${target}/.claude/skills" -name 'SKILL.md' 2>/dev/null | wc -l | tr -d ' ')
    commands=$(find "${target}/.claude/commands" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    agents=$(find "${target}/.claude/agents" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')

    if [[ -f "${target}/.claude/settings.json" ]] && command -v python3 >/dev/null 2>&1; then
        mcps=$(python3 -c "import json; s=json.load(open('${target}/.claude/settings.json')); print(len(s.get('mcpServers',{})))" 2>/dev/null || echo 0)
        hooks=$(python3 -c "import json; s=json.load(open('${target}/.claude/settings.json')); print(sum(len(v) for v in s.get('hooks',{}).values() if isinstance(v,list)))" 2>/dev/null || echo 0)
    fi

    # Domain
    local domain="unknown"
    if [[ -f "${target}/.claude/PROJECT_PROFILE.json" ]] && command -v python3 >/dev/null 2>&1; then
        domain=$(python3 -c "import json; p=json.load(open('${target}/.claude/PROJECT_PROFILE.json')); print(p.get('fingerprint',{}).get('domain','unknown').replace('_',' ').title())" 2>/dev/null || echo "unknown")
    fi

    echo -e "  ${BOLD}Project:${RESET}  $(basename "${target}")"
    echo -e "  ${BOLD}Path:${RESET}     ${target}"
    echo -e "  ${BOLD}Domain:${RESET}   ${domain}"
    echo ""
    echo -e "  ${BOLD}Components:${RESET}"
    echo -e "    ${GREEN}${skills}${RESET} skills  ${GREEN}${commands}${RESET} commands  ${GREEN}${agents}${RESET} agents  ${GREEN}${mcps}${RESET} MCPs  ${GREEN}${hooks}${RESET} hooks"
    echo ""

    # Config files
    echo -e "  ${BOLD}Config:${RESET}"
    for f in "CLAUDE.md" ".claude/settings.json" ".claude/PROJECT_PROFILE.json"; do
        if [[ -f "${target}/${f}" ]]; then
            local size=$(wc -c < "${target}/${f}" | tr -d ' ')
            echo -e "    ${GREEN}✓${RESET} ${f} ${DIM}(${size}b)${RESET}"
        else
            echo -e "    ${RED}✗${RESET} ${f} ${DIM}(missing)${RESET}"
        fi
    done
    echo ""

    echo -e "  ${CYAN}Tip:${RESET} Run ${BOLD}dee doctor${RESET} for a full health check"
    echo ""
}

cmd_doctor() {
    local target
    target=$(resolve_path "${1:-}")
    show_header

    if ! has_dee "${target}"; then
        log_error "No DEE installation found at: ${target}"
        return 1
    fi

    local score=100
    local issues=0

    echo -e "  ${BOLD}Running diagnostics on:${RESET} ${target}"
    echo ""

    # Core files
    echo -e "  ${BOLD}Core Files${RESET}"
    for f in "CLAUDE.md" ".claude/settings.json" ".claude/PROJECT_PROFILE.json"; do
        if [[ -f "${target}/${f}" ]]; then
            echo -e "    ${GREEN}✓${RESET} ${f}"
        else
            echo -e "    ${RED}✗${RESET} ${f} — missing"
            score=$((score - 5))
            issues=$((issues + 1))
        fi
    done
    echo ""

    # Skills quality
    echo -e "  ${BOLD}Skills${RESET}"
    local total_skills=0 good_skills=0 stub_skills=0 frontmatter_skills=0
    for skill_dir in "${target}/.claude/skills"/*/; do
        local smd="${skill_dir}SKILL.md"
        if [[ -f "${smd}" ]]; then
            total_skills=$((total_skills + 1))
            local size=$(wc -c < "${smd}" | tr -d ' ')
            if [[ ${size} -lt 200 ]]; then
                stub_skills=$((stub_skills + 1))
            else
                good_skills=$((good_skills + 1))
            fi
            if head -1 "${smd}" | grep -q "^---"; then
                frontmatter_skills=$((frontmatter_skills + 1))
            fi
        fi
    done
    echo -e "    ${GREEN}✓${RESET} ${good_skills}/${total_skills} skills with real content"
    if [[ ${stub_skills} -gt 0 ]]; then
        echo -e "    ${YELLOW}⚠${RESET} ${stub_skills} stub skills (< 200 bytes)"
        score=$((score - stub_skills))
        issues=$((issues + 1))
    fi
    if [[ ${frontmatter_skills} -gt 0 ]]; then
        echo -e "    ${RED}✗${RESET} ${frontmatter_skills} with YAML frontmatter (compatibility issue)"
        score=$((score - frontmatter_skills * 2))
        issues=$((issues + 1))
    fi
    echo ""

    # MCPs
    echo -e "  ${BOLD}MCPs${RESET}"
    if [[ -f "${target}/.claude/settings.json" ]] && command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json
s = json.load(open('${target}/.claude/settings.json'))
mcps = s.get('mcpServers', {})
ready = 0
needs_key = 0
for name, cfg in mcps.items():
    env = cfg.get('env', {})
    has_placeholder = any('your_' in str(v).lower() or 'xxx' in str(v).lower() or v == '' for v in env.values()) if env else False
    if env and has_placeholder:
        needs_key += 1
    else:
        ready += 1
print(f'    \033[0;32m✓\033[0m {ready} ready')
if needs_key > 0:
    print(f'    \033[1;33m⚠\033[0m {needs_key} need API keys')
print(f'    Total: {len(mcps)} servers')
" 2>/dev/null
    else
        echo -e "    ${DIM}Cannot check (no settings.json or python3)${RESET}"
    fi
    echo ""

    # Hooks
    echo -e "  ${BOLD}Hooks${RESET}"
    if [[ -f "${target}/.claude/settings.json" ]] && command -v python3 >/dev/null 2>&1; then
        local has_session=$(python3 -c "import json; s=json.load(open('${target}/.claude/settings.json')); print('yes' if 'SessionStart' in s.get('hooks',{}) else 'no')" 2>/dev/null)
        local has_post=$(python3 -c "import json; s=json.load(open('${target}/.claude/settings.json')); print('yes' if 'PostToolUse' in s.get('hooks',{}) else 'no')" 2>/dev/null)

        if [[ "${has_session}" == "yes" ]]; then
            echo -e "    ${GREEN}✓${RESET} SessionStart — project intelligence on startup"
        else
            echo -e "    ${RED}✗${RESET} SessionStart — missing"
            score=$((score - 10))
            issues=$((issues + 1))
        fi
        if [[ "${has_post}" == "yes" ]]; then
            echo -e "    ${GREEN}✓${RESET} PostToolUse — auto-verify code edits"
        else
            echo -e "    ${RED}✗${RESET} PostToolUse — missing"
            score=$((score - 10))
            issues=$((issues + 1))
        fi
    fi
    echo ""

    # Score
    [[ ${score} -lt 0 ]] && score=0
    local grade_color="${GREEN}" grade_label="HEALTHY"
    if [[ ${score} -lt 90 ]]; then grade_color="${GREEN}"; grade_label="GOOD"; fi
    if [[ ${score} -lt 70 ]]; then grade_color="${YELLOW}"; grade_label="NEEDS ATTENTION"; fi
    if [[ ${score} -lt 50 ]]; then grade_color="${RED}"; grade_label="CRITICAL"; fi

    echo -e "  ${BOLD}Score: ${grade_color}${score}/100 — ${grade_label}${RESET}"
    if [[ ${issues} -gt 0 ]]; then
        echo -e "  ${DIM}${issues} issue(s) found${RESET}"
    fi
    echo ""

    if [[ ${issues} -gt 0 ]]; then
        echo -e "  ${CYAN}Fix:${RESET} Run ${BOLD}dee update${RESET} to update all components"
        echo ""
    fi
}

cmd_uninstall() {
    local target
    target=$(resolve_path "${1:-}")
    show_header

    if ! has_dee "${target}"; then
        log_error "No DEE installation found at: ${target}"
        return 1
    fi

    echo -e "  ${YELLOW}This will remove the Devlmer Ecosystem Engine from:${RESET}"
    echo -e "  ${target}"
    echo ""
    echo -e "  ${BOLD}What will be removed:${RESET}"
    echo -e "    • .claude/skills/       (all skills)"
    echo -e "    • .claude/commands/     (slash commands)"
    echo -e "    • .claude/agents/       (agents)"
    echo -e "    • .claude/settings.json (hooks + MCPs)"
    echo -e "    • .claude/PROJECT_PROFILE.json"
    echo ""
    echo -e "  ${BOLD}What will NOT be removed:${RESET}"
    echo -e "    • CLAUDE.md (may contain your custom content)"
    echo -e "    • .claude/mcp-env-setup.sh (your API keys)"
    echo -e "    • Your project code"
    echo ""

    read -t 30 -p "  Remove? [y/N]: " confirm || confirm="n"

    if [[ "${confirm}" =~ ^[yY] ]]; then
        rm -rf "${target}/.claude/skills" "${target}/.claude/commands" "${target}/.claude/agents"
        rm -f "${target}/.claude/settings.json" "${target}/.claude/PROJECT_PROFILE.json"

        # Clean CLAUDE.md Devlmer section (keep user content)
        if [[ -f "${target}/CLAUDE.md" ]] && command -v python3 >/dev/null 2>&1; then
            python3 -c "
import re
with open('${target}/CLAUDE.md', 'r') as f:
    content = f.read()
if content.strip().startswith('# CLAUDE.md') and 'Devlmer' in content[:200]:
    # Entire file is DEE-generated
    import os
    os.remove('${target}/CLAUDE.md')
else:
    # Remove just the Devlmer section
    cleaned = re.sub(r'## Devlmer Ecosystem Engine.*?(?=\n## (?!Devlmer)|$)', '', content, flags=re.DOTALL).rstrip()
    with open('${target}/CLAUDE.md', 'w') as f:
        f.write(cleaned + '\n')
" 2>/dev/null
        fi

        echo ""
        log_success "Ecosystem removed from: ${target}"
        echo -e "  ${DIM}Your API keys are still in .claude/mcp-env-setup.sh${RESET}"
        echo ""
    else
        echo ""
        log_info "Cancelled"
        echo ""
    fi
}

# ============================================================================
# RELEASE — Interactive release wizard
# ============================================================================

# Helper: read input with a prompt and optional default
ask() {
    local prompt="$1"
    local default="${2:-}"
    local reply
    if [[ -n "${default}" ]]; then
        echo -ne "  ${CYAN}?${RESET} ${prompt} ${DIM}(${default})${RESET}: " >&2
    else
        echo -ne "  ${CYAN}?${RESET} ${prompt}: " >&2
    fi
    read -r reply
    echo "${reply:-${default}}"
}

# Helper: read multi-line items (one per line, empty line to finish)
ask_items() {
    local prompt="$1"
    echo -e "  ${CYAN}?${RESET} ${prompt} ${DIM}(una por línea, línea vacía para terminar)${RESET}" >&2
    local items=()
    while true; do
        echo -ne "    ${DIM}•${RESET} " >&2
        read -r line
        if [[ -z "${line}" ]]; then
            break
        fi
        items+=("${line}")
    done
    printf '%s\n' "${items[@]}"
}

cmd_release() {
    show_header

    echo -e "  ${BOLD}📦 Asistente de Release${RESET}"
    echo -e "  ${DIM}Te guiaré paso a paso para crear una nueva versión${RESET}"
    echo ""

    # ── Must be in the repo directory ──
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [[ -z "${repo_root}" ]]; then
        log_error "No estás en un repositorio git."
        echo -e "  ${DIM}Ejecuta este comando desde la carpeta del proyecto devlmer-ecosystem-engine${RESET}"
        exit 1
    fi
    cd "${repo_root}"

    # ── Show current version ──
    local current_version
    current_version=$(grep '^VERSION=' "${repo_root}/bin/dee" 2>/dev/null | head -1 | cut -d'"' -f2)
    local latest_tag
    latest_tag=$(git tag -l 'v*' --sort=-v:refname 2>/dev/null | head -1)
    echo -e "  ${DIM}Versión actual del CLI:${RESET}  v${current_version:-desconocida}"
    echo -e "  ${DIM}Último tag en git:${RESET}       ${latest_tag:-ninguno}"

    # ── Show recent commits since last tag ──
    if [[ -n "${latest_tag}" ]]; then
        local commit_count
        commit_count=$(git rev-list "${latest_tag}..HEAD" --count 2>/dev/null || echo "0")
        echo -e "  ${DIM}Commits desde ${latest_tag}:${RESET}    ${commit_count}"
        if [[ "${commit_count}" -gt 0 ]]; then
            echo ""
            echo -e "  ${DIM}Últimos cambios:${RESET}"
            git log "${latest_tag}..HEAD" --oneline --no-decorate 2>/dev/null | head -10 | while read -r line; do
                echo -e "    ${DIM}·${RESET} ${line}"
            done
        fi
    fi
    echo ""

    # ── Step 1: Ask for version ──
    echo -e "  ${BOLD}━━━ Paso 1/4: Versión ━━━${RESET}"
    echo ""

    local new_version="${1:-}"
    if [[ -z "${new_version}" ]]; then
        # Suggest next versions
        if [[ -n "${current_version}" ]]; then
            local major minor patch
            IFS='.' read -r major minor patch <<< "${current_version}"
            echo -e "  ${DIM}Sugerencias basadas en v${current_version}:${RESET}"
            echo -e "    ${GREEN}1${RESET}) v${major}.${minor}.$((patch + 1))  ${DIM}— patch (bugfixes)${RESET}"
            echo -e "    ${GREEN}2${RESET}) v${major}.$((minor + 1)).0  ${DIM}— minor (nuevas features)${RESET}"
            echo -e "    ${GREEN}3${RESET}) v$((major + 1)).0.0  ${DIM}— major (breaking changes)${RESET}"
            echo ""
        fi
        new_version=$(ask "Nueva versión (ej: 3.1.0)")
    fi

    # Handle shortcut numbers
    if [[ -n "${current_version}" ]]; then
        local major minor patch
        IFS='.' read -r major minor patch <<< "${current_version}"
        case "${new_version}" in
            1) new_version="${major}.${minor}.$((patch + 1))" ;;
            2) new_version="${major}.$((minor + 1)).0" ;;
            3) new_version="$((major + 1)).0.0" ;;
        esac
    fi

    # Strip leading 'v' if present
    new_version="${new_version#v}"

    if ! [[ "${new_version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        log_error "Formato inválido: ${new_version}. Usa MAJOR.MINOR.PATCH (ej: 3.1.0)"
        exit 1
    fi

    # Check tag doesn't exist
    if git tag -l | grep -q "^v${new_version}$"; then
        log_error "El tag v${new_version} ya existe. Usa otra versión."
        exit 1
    fi

    log_success "Versión: v${new_version}"
    echo ""

    # ── Step 2: Ask for release title ──
    echo -e "  ${BOLD}━━━ Paso 2/4: Título del release ━━━${RESET}"
    echo ""
    local release_title
    release_title=$(ask "Título corto (ej: Interactive Release Wizard)" "Release v${new_version}")
    echo ""

    # ── Step 3: Ask for changes ──
    echo -e "  ${BOLD}━━━ Paso 3/4: ¿Qué cambió? ━━━${RESET}"
    echo ""

    local added_items="" changed_items="" fixed_items="" removed_items=""

    # Agregado
    echo -ne "  ${CYAN}?${RESET} ¿Hay cosas ${GREEN}nuevas${RESET} (Agregado)? ${DIM}(s/n)${RESET}: "
    read -r has_added
    if [[ "${has_added}" =~ ^[sS] ]]; then
        added_items=$(ask_items "Describe cada cosa nueva")
    fi
    echo ""

    # Cambiado
    echo -ne "  ${CYAN}?${RESET} ¿Hay cosas ${YELLOW}cambiadas${RESET} (Cambiado)? ${DIM}(s/n)${RESET}: "
    read -r has_changed
    if [[ "${has_changed}" =~ ^[sS] ]]; then
        changed_items=$(ask_items "Describe cada cambio")
    fi
    echo ""

    # Corregido
    echo -ne "  ${CYAN}?${RESET} ¿Hay ${MAGENTA}correcciones${RESET} (Corregido)? ${DIM}(s/n)${RESET}: "
    read -r has_fixed
    if [[ "${has_fixed}" =~ ^[sS] ]]; then
        fixed_items=$(ask_items "Describe cada fix")
    fi
    echo ""

    # Eliminado
    echo -ne "  ${CYAN}?${RESET} ¿Se ${RED}eliminó${RESET} algo (Eliminado)? ${DIM}(s/n)${RESET}: "
    read -r has_removed
    if [[ "${has_removed}" =~ ^[sS] ]]; then
        removed_items=$(ask_items "Describe lo eliminado")
    fi
    echo ""

    # ── Build CHANGELOG entry ──
    local changelog_entry=""
    changelog_entry+="## [${new_version}] - $(date +%Y-%m-%d)"$'\n'
    changelog_entry+=""$'\n'

    if [[ -n "${added_items}" ]]; then
        changelog_entry+="### Agregado"$'\n'
        while IFS= read -r item; do
            [[ -n "${item}" ]] && changelog_entry+="- ${item}"$'\n'
        done <<< "${added_items}"
        changelog_entry+=""$'\n'
    fi

    if [[ -n "${changed_items}" ]]; then
        changelog_entry+="### Cambiado"$'\n'
        while IFS= read -r item; do
            [[ -n "${item}" ]] && changelog_entry+="- ${item}"$'\n'
        done <<< "${changed_items}"
        changelog_entry+=""$'\n'
    fi

    if [[ -n "${fixed_items}" ]]; then
        changelog_entry+="### Corregido"$'\n'
        while IFS= read -r item; do
            [[ -n "${item}" ]] && changelog_entry+="- ${item}"$'\n'
        done <<< "${fixed_items}"
        changelog_entry+=""$'\n'
    fi

    if [[ -n "${removed_items}" ]]; then
        changelog_entry+="### Eliminado"$'\n'
        while IFS= read -r item; do
            [[ -n "${item}" ]] && changelog_entry+="- ${item}"$'\n'
        done <<< "${removed_items}"
        changelog_entry+=""$'\n'
    fi

    # If nothing was entered, add a default
    if [[ -z "${added_items}" && -z "${changed_items}" && -z "${fixed_items}" && -z "${removed_items}" ]]; then
        changelog_entry+="### Agregado"$'\n'
        changelog_entry+="- Release v${new_version}"$'\n'
        changelog_entry+=""$'\n'
    fi

    # ── Step 4: Preview and confirm ──
    echo -e "  ${BOLD}━━━ Paso 4/4: Confirmar ━━━${RESET}"
    echo ""
    echo -e "  ${BOLD}Vista previa del CHANGELOG:${RESET}"
    echo -e "  ${DIM}─────────────────────────────────${RESET}"
    echo "${changelog_entry}" | while IFS= read -r line; do
        echo -e "  ${DIM}│${RESET} ${line}"
    done
    echo -e "  ${DIM}─────────────────────────────────${RESET}"
    echo ""
    echo -e "  ${BOLD}Se ejecutará:${RESET}"
    echo -e "    ${DIM}1.${RESET} Actualizar CHANGELOG.md"
    echo -e "    ${DIM}2.${RESET} Actualizar versión en bin/dee e install.sh"
    echo -e "    ${DIM}3.${RESET} Commit + tag v${new_version}"
    echo -e "    ${DIM}4.${RESET} Push a GitHub"
    echo -e "    ${DIM}5.${RESET} Crear GitHub Release: ${CYAN}${release_title}${RESET}"
    echo ""

    echo -ne "  ${CYAN}?${RESET} ¿Proceder con el release v${new_version}? ${DIM}(s/n)${RESET}: "
    read -r confirm
    if ! [[ "${confirm}" =~ ^[sS] ]]; then
        echo ""
        log_info "Cancelado"
        echo ""
        exit 0
    fi

    echo ""
    echo -e "  ${BOLD}🚀 Ejecutando release...${RESET}"
    echo ""

    # ── Update CHANGELOG.md ──
    if [[ -f "CHANGELOG.md" ]]; then
        # Insert new entry after the first "# Changelog" line (or after the first ---)
        local tmp_cl="${repo_root}/.changelog_tmp"
        local prev_version="${current_version}"
        local link_line="[${new_version}]: https://github.com/Soyelijah/devlmer-ecosystem-engine/compare/v${prev_version}...v${new_version}"

        python3 << PYEOF
import re

with open("CHANGELOG.md", "r") as f:
    content = f.read()

new_entry = """${changelog_entry}---
"""

# Insert after the first "---" separator or after "# Changelog\n"
if "\n---\n" in content:
    # Insert after first ---
    pos = content.index("\n---\n") + len("\n---\n")
    content = content[:pos] + "\n" + new_entry + "\n" + content[pos:]
elif content.startswith("# "):
    # Insert after first header paragraph
    lines = content.split("\n")
    insert_idx = 1
    # Skip blank lines after header
    while insert_idx < len(lines) and lines[insert_idx].strip() == "":
        insert_idx += 1
    # Skip subtitle lines
    while insert_idx < len(lines) and lines[insert_idx].strip() and not lines[insert_idx].startswith("## "):
        insert_idx += 1
    lines.insert(insert_idx, "\n---\n\n" + new_entry)
    content = "\n".join(lines)
else:
    content = "# Changelog\n\n---\n\n" + new_entry + "\n" + content

# Add link at bottom if not present
if "[${new_version}]:" not in content:
    content = content.rstrip() + "\n${link_line}\n"

with open("CHANGELOG.md", "w") as f:
    f.write(content)
PYEOF
        log_success "CHANGELOG.md actualizado"
    else
        # Create from scratch
        cat > CHANGELOG.md << CLEOF
# Changelog

---

${changelog_entry}
[${new_version}]: https://github.com/Soyelijah/devlmer-ecosystem-engine/releases/tag/v${new_version}
CLEOF
        log_success "CHANGELOG.md creado"
    fi

    # ── Update version in bin/dee ──
    local dee_file="${repo_root}/bin/dee"
    if [[ -f "${dee_file}" ]]; then
        local old_ver
        old_ver=$(grep '^VERSION=' "${dee_file}" | head -1 | cut -d'"' -f2)
        if [[ "${old_ver}" != "${new_version}" ]]; then
            sed -i.bak "s/^VERSION=\"${old_ver}\"/VERSION=\"${new_version}\"/" "${dee_file}"
            rm -f "${dee_file}.bak"
            log_success "bin/dee: v${old_ver} → v${new_version}"
        fi
    fi

    # ── Update version in install.sh ──
    local install_file="${repo_root}/install.sh"
    if [[ -f "${install_file}" ]]; then
        if grep -q 'DEE_VERSION=' "${install_file}"; then
            sed -i.bak "s/DEE_VERSION=\"[^\"]*\"/DEE_VERSION=\"${new_version}\"/" "${install_file}"
            rm -f "${install_file}.bak"
            log_success "install.sh version actualizada"
        fi
    fi

    # ── Commit ──
    git add -A
    git commit -m "release: v${new_version} — ${release_title}" --quiet 2>/dev/null
    log_success "Cambios commiteados"

    # ── Tag ──
    git tag -a "v${new_version}" -m "Devlmer Ecosystem Engine v${new_version} — ${release_title}" 2>/dev/null
    log_success "Tag v${new_version} creado"

    # ── Push ──
    log_info "Pushing a GitHub..."
    git push origin main --quiet 2>/dev/null
    git push origin "v${new_version}" --quiet 2>/dev/null
    log_success "Push completo"

    # ── Create GitHub Release ──
    log_info "Creando GitHub Release..."

    # Build release body from changelog entry
    local release_body="${changelog_entry}"
    release_body+=$'\n'"---"$'\n'
    release_body+=$'\n'"### Instalación"$'\n'
    release_body+='```bash'$'\n'
    release_body+="rm -rf /tmp/dee && git clone https://github.com/Soyelijah/devlmer-ecosystem-engine.git /tmp/dee && bash /tmp/dee/install.sh ~/Projects/mi-app"$'\n'
    release_body+='```'$'\n'
    release_body+=$'\n'"### Actualización"$'\n'
    release_body+='```bash'$'\n'
    release_body+="dee update"$'\n'
    release_body+='```'$'\n'

    local gh_created=false

    # Try gh CLI first
    if command -v gh &>/dev/null; then
        if gh release create "v${new_version}" \
            --title "v${new_version} — ${release_title}" \
            --notes "${release_body}" 2>/dev/null; then
            gh_created=true
            log_success "GitHub Release creado (gh CLI)"
        fi
    fi

    # Fallback: curl with token from remote
    if [[ "${gh_created}" == "false" ]]; then
        local token=""
        local remote_url
        remote_url=$(git remote get-url origin 2>/dev/null || true)
        if [[ "${remote_url}" =~ https://([^@]+)@github.com ]]; then
            token="${BASH_REMATCH[1]}"
        fi

        # Also check GITHUB_TOKEN env var
        if [[ -z "${token}" && -n "${GITHUB_TOKEN:-}" ]]; then
            token="${GITHUB_TOKEN}"
        fi

        if [[ -n "${token}" ]]; then
            local json_body
            json_body=$(python3 -c "
import json, sys
body = sys.stdin.read()
print(json.dumps({
    'tag_name': 'v${new_version}',
    'name': 'v${new_version} — $(echo "${release_title}" | sed "s/'/\\\\'/g")',
    'body': body,
    'draft': False,
    'prerelease': False
}))
" <<< "${release_body}" 2>/dev/null)

            if [[ -n "${json_body}" ]]; then
                # Detect repo from remote URL
                local repo_slug
                repo_slug=$(echo "${remote_url}" | sed -E 's|.*github\.com[:/]||; s|\.git$||; s|https://[^@]+@||')
                if [[ -z "${repo_slug}" ]]; then
                    repo_slug="Soyelijah/devlmer-ecosystem-engine"
                fi

                local http_code
                http_code=$(curl -s -o /dev/null -w "%{http_code}" \
                    -X POST "https://api.github.com/repos/${repo_slug}/releases" \
                    -H "Authorization: token ${token}" \
                    -H "Accept: application/vnd.github+json" \
                    -H "Content-Type: application/json" \
                    -d "${json_body}" 2>/dev/null || echo "000")

                if [[ "${http_code}" == "201" ]]; then
                    log_success "GitHub Release creado (API)"
                else
                    log_warning "No se pudo crear el Release automáticamente (HTTP ${http_code})"
                    echo -e "  ${DIM}Créalo manualmente: https://github.com/Soyelijah/devlmer-ecosystem-engine/releases/new?tag=v${new_version}${RESET}"
                fi
            fi
        else
            log_warning "Sin token de GitHub — crea el Release manualmente"
            echo -e "  ${DIM}https://github.com/Soyelijah/devlmer-ecosystem-engine/releases/new?tag=v${new_version}${RESET}"
        fi
    fi

    # ── Done! ──
    echo ""
    echo -e "  ${BOLD}${GREEN}╔══════════════════════════════════════════════════╗${RESET}"
    echo -e "  ${BOLD}${GREEN}║     ✓ Release v${new_version} publicado exitosamente!     ║${RESET}"
    echo -e "  ${BOLD}${GREEN}╚══════════════════════════════════════════════════╝${RESET}"
    echo ""
    echo -e "  ${DIM}Tag:${RESET}       v${new_version}"
    echo -e "  ${DIM}Título:${RESET}    ${release_title}"
    echo -e "  ${DIM}Release:${RESET}   https://github.com/Soyelijah/devlmer-ecosystem-engine/releases/tag/v${new_version}"
    echo ""
    echo -e "  ${DIM}Los usuarios recibirán estos cambios con:${RESET} ${BOLD}dee update${RESET}"
    echo ""
}

# ============================================================================
# MAIN — Route to command
# ============================================================================

main() {
    local cmd="${1:-help}"

    case "${cmd}" in
        install)    cmd_install "${2:-}" "${3:-}" ;;
        update)     cmd_update "${2:-}" ;;
        status)     cmd_status "${2:-}" ;;
        doctor)     cmd_doctor "${2:-}" ;;
        uninstall)  cmd_uninstall "${2:-}" ;;
        release)    cmd_release "${2:-}" ;;
        self-update|selfupdate|upgrade)  cmd_self_update ;;
        version|-v|--version)  cmd_version ;;
        help|-h|--help)        cmd_help ;;
        *)
            log_error "Unknown command: ${cmd}"
            echo ""
            echo -e "  Run ${BOLD}dee help${RESET} for usage"
            echo ""
            exit 1
            ;;
    esac
}

main "$@"
